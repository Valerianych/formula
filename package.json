{
  "name": "f1-race-analytics",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production tsx server.ts",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "cache:year": "tsx scripts/cacheYear.ts",
    "cache:2025": "tsx scripts/cacheYear.ts 2025",
    "cache:2024": "tsx scripts/cacheYear.ts 2024",
    "cache:current": "tsx scripts/cacheCurrentSeason.ts",
    "cache:current:2026": "tsx scripts/cacheCurrentSeason.ts 2026",
    "cache:results": "tsx scripts/cache_results.ts",
    "cache:results:2024": "tsx scripts/cache_results.ts 2024",
    "cache:results:2025": "tsx scripts/cache_results.ts 2025",
    "cache:results:2026": "tsx scripts/cache_results.ts 2026",
    "cache:site": "tsx scripts/cache_site_data_v2.ts",
    "cache:site:2024": "tsx scripts/cache_site_data_v2.ts 2024 && npm run cache:repair:2024",
    "cache:site:2025": "tsx scripts/cache_site_data_v2.ts 2025 && npm run cache:repair:2025",
    "cache:site:2026": "tsx scripts/cache_site_data_v2.ts 2026 && npm run cache:repair:2026",
    "cache:fastf1": "python scripts/fastf1_cache.py",
    "cache:fastf1:2024": "python scripts/fastf1_cache.py 2024",
    "cache:fastf1:2024:telemetry": "python scripts/fastf1_cache.py 2024 --telemetry",
    "cache:fastf1:2025": "python scripts/fastf1_cache.py 2025",
    "cache:fastf1:2026": "python scripts/fastf1_cache.py 2026",
    "cache:fastf1:2026:telemetry": "python scripts/fastf1_cache.py 2026 --telemetry",
    "cache:maps": "python scripts/cache_maps.py",
    "cache:maps:2024": "python scripts/cache_maps.py 2024",
    "cache:maps:2025": "python scripts/cache_maps.py 2025",
    "cache:maps:2026": "python scripts/cache_maps.py 2026",
    "cache:repair": "tsx scripts/repair_cache_display.ts",
    "cache:repair:2024": "tsx scripts/repair_cache_display.ts 2024",
    "cache:repair:2025": "tsx scripts/repair_cache_display.ts 2025",
    "cache:repair:2026": "tsx scripts/repair_cache_display.ts 2026",
    "cache:all:2024": "npm run cache:2024 && npm run cache:site:2024",
    "cache:all:2025": "npm run cache:2025 && npm run cache:site:2025",
    "cache:all:2026": "npm run cache:current:2026 && npm run cache:site:2026"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
