# Optional Gemini fallback provider.
# Keep real values only in deployment secrets, not in git.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"

# App URL for deployment callbacks/self links if needed.
APP_URL=""

# GigaChat is the main AI provider for this project.
# GIGACHAT_AUTH_KEY is the Base64 Authorization Key from the GigaChat console.
GIGACHAT_AUTH_KEY=""
GIGACHAT_SCOPE="GIGACHAT_API_PERS"
GIGACHAT_MODEL="GigaChat"
GIGACHAT_OAUTH_URL="https://ngw.devices.sberbank.ru:9443/api/v2/oauth"
GIGACHAT_API_BASE="https://gigachat.devices.sberbank.ru/api/v1"
